# CodeCraft AI Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=5000
NODE_ENV=development

# LLM (Cohere)
COHERE_API_KEY=your_cohere_api_key_here

# RAG (Pinecone)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=codecraft-index

# MongoDB (optional - for session persistence)
DB_URL=mongodb+srv://...
USE_MONGO_SESSION=false

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
CALL_BACK_URL=http://localhost:5000/auth/github/callback
COOKIE_KEY=your_session_secret_here

# Frontend
FRONT_APP_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
