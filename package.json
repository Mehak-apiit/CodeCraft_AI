{
  "name": "codecraftai",
  "version": "1.0.0",
  "description": "Autonomous AI coding agent system with memory, RAG, and multi-agent orchestration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "agent": "ts-node src/agent.ts",
    "test": "ts-node --transpile-only tests/test-registry.ts && ts-node --transpile-only tests/test-tools.ts",
    "test:registry": "ts-node --transpile-only tests/test-registry.ts",
    "test:tools": "ts-node --transpile-only tests/test-tools.ts",
    "test:memory": "ts-node --transpile-only tests/test-memory-agent.ts",
    "test:agents": "ts-node --transpile-only tests/test-agents.ts",
    "test:all": "ts-node --transpile-only tests/test-registry.ts && ts-node --transpile-only tests/test-tools.ts && ts-node --transpile-only tests/test-memory-agent.ts && ts-node --transpile-only tests/test-agents.ts",
    "typecheck": "tsc --noEmit",
    "file": "ts-node src/tools/ast.ts"
  },
  "keywords": ["ai", "coding-agent", "rag", "multi-agent", "langchain"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@babel/parser": "^8.0.0",
    "@langchain/cohere": "^1.1.0",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint-mongodb": "^1.4.0",
    "@langchain/pinecone": "^1.0.3",
    "@langchain/textsplitters": "^1.0.1",
    "@types/adm-zip": "^0.5.8",
    "@types/multer": "^2.2.0",
    "adm-zip": "^0.6.0",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "glob": "^13.0.6",
    "langchain": "^1.5.2",
    "multer": "^2.2.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "simple-git": "^3.36.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express-session": "^1.19.0",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
